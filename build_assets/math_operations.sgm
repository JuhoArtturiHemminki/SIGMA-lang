struct Complex {
    re: f64,
    im: f64
}

struct FFTBuffer {
    data: [Complex; 1024],
    size: u32
}

fn butterfly_op(root: Axis<FFTBuffer>, i: u32, j: u32, w_re: f64, w_im: 
f64) {
    step@90(root) -> p_calc {
        p_calc.point(|fft| {
            let u = fft.data[i];
            let v_re = fft.data[j].re * w_re - fft.data[j].im * w_im;
            let v_im = fft.data[j].re * w_im + fft.data[j].im * w_re;
            
            fft.data[i].re = u.re + v_re;
            fft.data[i].im = u.im + v_im;
            fft.data[j].re = u.re - v_re;
            fft.data[j].im = u.im - v_im;
        });
    }
}

fn compute_magnitude(root: Axis<Complex>) -> f64 {
    let mut res: f64 = 0.0;
    step@0(root) -> p_origin {
        p_origin.point(|c| {
            res = (c.re * c.re + c.im * c.im).sqrt();
        });
    }
    res
}

fn solve_rotation(p: Phase<Complex, 0>) -> Phase<Complex, 360> {
    rotate p to @180 -> p1 {
        p1.point(|c| {
            c.re = -c.re;
            c.im = -c.im;
        });
    }
    
    rotate p1 to @360 -> p2 {
        sync(p2)
    }
}

