struct Body {
    x: f64, y: f64, z: f64,
    vx: f64, vy: f64, vz: f64,
    mass: f64
}

struct System {
    bodies: [Body; 64],
    count: u32
}

fn apply_gravity(root: Axis<System>, g: f64, dt: f64) {
    step@0(root) -> p_read {
        step@180(root) -> p_write {
            p_write.point(|sys| {
                let mut i = 0;
                while i < sys.count {
                    let mut fx = 0.0;
                    let mut fy = 0.0;
                    let mut fz = 0.0;
                    
                    let mut j = 0;
                    while j < sys.count {
                        if i != j {
                            let dx = p_read.bodies[j].x - sys.bodies[i].x;
                            let dy = p_read.bodies[j].y - sys.bodies[i].y;
                            let dz = p_read.bodies[j].z - sys.bodies[i].z;
                            let dist = (dx*dx + dy*dy + dz*dz + 
0.01).sqrt();
                            let mag = g * sys.bodies[i].mass * 
p_read.bodies[j].mass / (dist * dist * dist);
                            
                            fx += dx * mag;
                            fy += dy * mag;
                            fz += dz * mag;
                        }
                        j += 1;
                    }
                    
                    sys.bodies[i].vx += fx * dt / sys.bodies[i].mass;
                    sys.bodies[i].vy += fy * dt / sys.bodies[i].mass;
                    sys.bodies[i].vz += fz * dt / sys.bodies[i].mass;
                    i += 1;
                }
            });
        }
    }
}

fn integrate_motion(root: Axis<System>, dt: f64) {
    rotate root.initialize_at::<0>() to @360 -> p_sync {
        p_sync.point(|sys| {
            let mut i = 0;
            while i < sys.count {
                sys.bodies[i].x += sys.bodies[i].vx * dt;
                sys.bodies[i].y += sys.bodies[i].vy * dt;
                sys.bodies[i].z += sys.bodies[i].vz * dt;
                i += 1;
            }
        });
        sync(p_sync);
    }
}

