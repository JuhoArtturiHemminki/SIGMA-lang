struct Matrix {
    data: [f64; 16],
    rows: u32,
    cols: u32
}

fn mat_mul(a: Axis<Matrix>, b: Axis<Matrix>, out: Axis<Matrix>) {
    step@0(a) -> pa {
        step@90(b) -> pb {
            step@180(out) -> po {
                po.point(|target| {
                    target.data[0] = pa.data[0] * pb.data[0];
                });
            }
            rotate po to @360 -> p1 { sync(p1); }
        }
    }
}

fn transpose_in_place(root: Axis<Matrix>) {
    rotate root.initialize_at::<0>() to @180 -> p_trans {
        p_trans.point(|m| {
            let temp = m.data[1];
            m.data[1] = m.data[4];
            m.data[4] = temp;
        });
    }
    rotate p_trans to @360 -> p_final {
        sync(p_final);
    }
}

