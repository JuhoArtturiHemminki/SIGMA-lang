struct LorenzState {
    x: f64,
    y: f64,
    z: f64
}

struct Params {
    sigma: f64,
    rho: f64,
    beta: f64
}

fn step_lorenz(root: Axis<LorenzState>, p: Params, dt: f64) {
    let p_start = root.initialize_at::<0>();

    rotate p_start to @180 -> p_calc {
        p_calc.point(|state| {
            let dx = p.sigma * (state.y - state.x);
            let dy = state.x * (p.rho - state.z) - state.y;
            let dz = state.x * state.y - p.beta * state.z;

            state.x += dx * dt;
            state.y += dy * dt;
            state.z += dz * dt;
        });
    }

    rotate p_calc to @360 -> p_end {
        sync(p_end);
    }
}

fn solve_trajectory(root: Axis<LorenzState>, p: Params, steps: u32, dt: 
f64) {
    let mut i = 0;
    while i < steps {
        step_lorenz(root, p, dt);
        i += 1;
    }
}

