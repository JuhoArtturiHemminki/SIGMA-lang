#!/bin/bash

BIN_DIR="$(cd "$(dirname "${BASH_SOURCE}")" && pwd)"
PARENT_DIR="$(dirname "$BIN_DIR")"

echo -e "\x1b[1;36mΣ VORTEX-LAUNCHER\x1b[0m | Initializing..."

if [ -f "$PARENT_DIR/target/debug/sigma-compiler" ]; then
    "$PARENT_DIR/target/debug/sigma-compiler" "$@"
else
    echo -e "\x1b[1;31m[ERROR]\x1b[0m Binary not found. Run 'cargo build' 
first."
fi

